{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022", "DOM"],
    "types": ["chrome", "node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
